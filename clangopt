#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import sys
import subprocess
import json
import hashlib
import argparse
from copy import deepcopy

# 1. 参数解析：从 .cfg 的 CC/CXX 定义中获取参数
parser = argparse.ArgumentParser()
parser.add_argument('--opt-cfg-json', default='', help='Path to GA config')
parser.add_argument('--llvm-dir', default='/data/llvm14_0_0/bin', help='LLVM bin path')
parser.add_argument('--optlevel', default='-O3', help='Fallback opt level')
args, unknown = parser.parse_known_args()

class ClangOptWrapper:
    def __init__(self):
        # 自动识别是 C 还是 C++
        self.is_cpp = '++' in sys.argv[0] or 'clangxx' in sys.argv[0]
        self.compiler = 'clang++' if self.is_cpp else 'clang'
        self.llvm_dir = args.llvm_dir
        
        # 建立 IR 持久化存储目录 (在用户目录下，不会随 rebuild 被删)
        self.ir_cache_dir = os.path.expanduser('~/.spec_ir_cache')
        os.makedirs(self.ir_cache_dir, exist_ok=True)

        # 加载遗传算法提供的 Pass 序列
        self.pass_str = args.optlevel
        if args.opt_cfg_json and os.path.isfile(args.opt_cfg_json):
            try:
                with open(args.opt_cfg_json, 'r') as f:
                    cfg = json.load(f)
                    self.pass_str = cfg.get('params', args.optlevel)
            except:
                pass

    def run(self):
        # 判断当前命令是否包含源文件（编译步）
        sources = [a for a in unknown if a.endswith(('.c', '.cpp', '.cc', '.C', '.cxx'))]
        
        if sources:
            self.compile_step(sources)
        
        # 判断是否需要执行链接（不带 -c 或 -S）
        if '-c' not in unknown and '-S' not in unknown:
            self.link_step()

    def compile_step(self, sources):
        # 使用 -MJ 探测输出文件名 (-o)
        hash_id = hashlib.md5((' '.join(unknown)).encode()).hexdigest()
        mj_file = os.path.join(self.ir_cache_dir, f"mj_{hash_id}.json")
        
        mj_cmd = [os.path.join(self.llvm_dir, self.compiler)] + unknown + ['-MJ', mj_file]
        subprocess.run(mj_cmd, capture_output=True)
        
        if not os.path.exists(mj_file):
            # 如果 MJ 失败，回退到原始编译以防万一
            subprocess.run([os.path.join(self.llvm_dir, self.compiler)] + unknown)
            return

        with open(mj_file, 'r') as f:
            content = f.read().strip().strip(',')
            cdb = json.loads(f"[{content}]")
        os.remove(mj_file)

        for entry in cdb:
            src = entry['file']
            obj = entry['output']
            cwd = entry['directory']

            # 为每个源文件创建唯一的 Baseline IR 文件名
            # 基于绝对路径 MD5，确保不同 benchmark 的同名文件不冲突
            file_uid = hashlib.md5(os.path.abspath(src).encode()).hexdigest()
            baseline_ir = os.path.join(self.ir_cache_dir, f"{file_uid}_base.bc")
            optimized_ir = os.path.join(cwd, f"{file_uid}_opt.bc")

            # --- 步骤 1: 生成/读取 Baseline IR ---
            if not os.path.exists(baseline_ir):
                # 过滤掉原始参数中的 -o, -c 和优化等级
                filtered_args = [a for a in unknown if a not in [src, obj, '-o', '-c', '-S'] and not a.startswith('-O')]
                
                # 生成不带优化属性的原始 IR (-Xclang -disable-llvm-optzns 是关键)
                # 必须带 -fPIC 以保证后续 llc 链接时不报错
                cmd_base = [os.path.join(self.llvm_dir, self.compiler), 
                            '-emit-llvm', '-c', '-fPIC', 
                            '-Xclang', '-disable-llvm-optzns', 
                            src] + filtered_args + ['-o', baseline_ir]
                
                res = subprocess.run(cmd_base, cwd=cwd, capture_output=True)
                if res.returncode != 0:
                    print(f"Error generating IR for {src}: {res.stderr.decode()}", file=sys.stderr)
                    sys.exit(1)

            # --- 步骤 2: 应用 GA 优化 Pass (使用 Legacy PM) ---
            # self.pass_str 是来自 GA 的那一串 Pass
            cmd_opt = [os.path.join(self.llvm_dir, 'opt'), '-enable-new-pm=0'] + \
                      self.pass_str.split() + [baseline_ir, '-o', optimized_ir]
            
            res_opt = subprocess.run(cmd_opt, capture_output=True)
            if res_opt.returncode != 0:
                # 如果 GA 提供的 Pass 序列导致 opt 崩溃，回退到标准 -O3 以保证 GA 流程不中断
                print(f"Warning: Opt failed for {src}, falling back to -O3", file=sys.stderr)
                cmd_fallback = [os.path.join(self.llvm_dir, 'opt'), '-enable-new-pm=0', '-O3', baseline_ir, '-o', optimized_ir]
                subprocess.run(cmd_fallback)

            # --- 步骤 3: 汇编生成目标文件 (llc) ---
            cmd_llc = [os.path.join(self.llvm_dir, 'llc'), '-O3', 
                       '-filetype=obj', '-relocation-model=pic', 
                       optimized_ir, '-o', obj]
            subprocess.run(cmd_llc, check=True)

    def link_step(self):
        # 提取链接参数，并确保库文件 (-l, -L) 放在最后
        flags = []
        libs = []
        for a in unknown:
            if a.endswith(('.c', '.cpp', '.cc', '.C', '.cxx')): continue
            if a.startswith(('-l', '-L')):
                libs.append(a)
            else:
                flags.append(a)
        
        # 强制补上数学库链接，解决 sqrt 等未定义问题
        if '-lm' not in libs:
            libs.append('-lm')
            
        final_link = [os.path.join(self.llvm_dir, self.compiler)] + flags + libs
        
        # 如果是 C++，通常还要确保链接了标准库
        if self.is_cpp and '-lstdc++' not in libs:
            final_link.append('-lstdc++')

        res = subprocess.run(final_link)
        if res.returncode != 0:
            print(f"Link failed: {' '.join(final_link)}", file=sys.stderr)
            sys.exit(1)

if __name__ == "__main__":
    # 打印收到的参数，方便调试 cat make.out 时查看
    print(f"Wrapper received args: {' '.join(sys.argv)}")
    ClangOptWrapper().run()